using AppointmentApp.Controller;
using AppointmentApp.Model;

namespace AppointmentApp.View;

public partial class AddAppointmentWindow : Form
{
    private readonly AppointmentController _controller;
    private readonly string _currentUserId;
    private readonly Appointment? _existingApp;
    private readonly List<Reminder> _reminders = new();

    public AddAppointmentWindow(AppointmentController controller, string currentUserId, DateTime selectedDate, Appointment? existingApp = null)
    {
        _controller = controller;
        _currentUserId = currentUserId;
        _existingApp = existingApp;
        InitializeComponent();

        if (_existingApp != null)
        {
            Text = "Edit Appointment";
            nameTextBox.Text = _existingApp.Name;
            locationTextBox.Text = _existingApp.Location;
            startPicker.Value = _existingApp.StartTime;
            endPicker.Value = _existingApp.EndTime;
            reminderTimePicker.Value = _existingApp.StartTime;
        }
        else
        {
            startPicker.Value = selectedDate;
            endPicker.Value = selectedDate.AddHours(1);
            reminderTimePicker.Value = selectedDate;
        }
    }

    public bool ValidateBasic(string name, DateTime start, DateTime end)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(locationTextBox.Text))
        {
            return false;
        }

        return end > start;
    }

    public void ShowValidationError()
    {
        MessageBox.Show("Please fill name/location and ensure end > start.", "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
    }

    public void ShowConflictWarning(Appointment? app)
    {
        if (app == null)
        {
            MessageBox.Show("Time conflict detected.", "Conflict", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            return;
        }

        var msg = $"Conflicts with: {app.Name} ({app.StartTime:yyyy-MM-dd HH:mm} - {app.EndTime:yyyy-MM-dd HH:mm})";
        MessageBox.Show(msg, "Conflict", MessageBoxButtons.OK, MessageBoxIcon.Warning);
    }

    public void ShowTimePicker()
    {
        MessageBox.Show("Please choose a new time and save again.", "Change Time", MessageBoxButtons.OK, MessageBoxIcon.Information);
        startPicker.Focus();
    }

    public bool ShowJoinGroupPrompt(GroupMeeting? meeting)
    {
        var title = meeting == null ? "Join group meeting" : $"Join group meeting: {meeting.Name}?";
        var result = MessageBox.Show(title, "Group Meeting", MessageBoxButtons.YesNo, MessageBoxIcon.Question);
        return result == DialogResult.Yes;
    }

    public void ShowSuccessMessage(string msg)
    {
        MessageBox.Show(msg, "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
    }

    public void ShowCancelMessage()
    {
        MessageBox.Show("Add appointment canceled.", "Canceled", MessageBoxButtons.OK, MessageBoxIcon.Information);
    }

    private void addReminderButton_Click(object sender, EventArgs e)
    {
        var reminder = new Reminder
        {
            ReminderTime = reminderTimePicker.Value
        };

        _reminders.Add(reminder);
        var item = new ListViewItem(reminder.ReminderTime.ToString("yyyy-MM-dd HH:mm"));
        remindersList.Items.Add(item);
    }

    private void saveButton_Click(object sender, EventArgs e)
    {
        var name = nameTextBox.Text.Trim();
        var location = locationTextBox.Text.Trim();
        var start = startPicker.Value;
        var end = endPicker.Value;

        if (!ValidateBasic(name, start, end))
        {
            ShowValidationError();
            return;
        }

        if (_existingApp != null)
        {
            _controller.UpdateAppointment(_existingApp.AppId, name, location, start, end, new List<Reminder>(_reminders));
            ShowSuccessMessage("Appointment updated.");
            Close();
            return;
        }

        var result = _controller.SubmitAppointment(name, location, start, end, new List<Reminder>(_reminders));
        HandleSubmitResult(result, name, location, start, end);
    }

    private void HandleSubmitResult(SubmitResult result, string name, string location, DateTime start, DateTime end)
    {
        if (result.Status == SubmitStatus.ValidationError)
        {
            MessageBox.Show(result.Message, "Validation", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            return;
        }

        if (result.Status == SubmitStatus.Conflict)
        {
            ShowConflictWarning(result.ConflictingAppointment);

            using var dialog = new ConflictDecisionDialog();
            dialog.ShowDialog(this);
            var decision = dialog.Decision;

            if (decision == ConflictDecision.Replace && result.ConflictingAppointment != null)
            {
                var replaceResult = _controller.ConfirmReplace(
                    result.ConflictingAppointment.AppId,
                    name,
                    location,
                    start,
                    end,
                    new List<Reminder>(_reminders));

                HandleSubmitResult(replaceResult, name, location, start, end);
                return;
            }

            if (decision == ConflictDecision.ChangeTime)
            {
                ShowTimePicker();
                return;
            }

            ShowCancelMessage();
            Close();
            return;
        }

        if (result.Status == SubmitStatus.SuggestGroup)
        {
            var join = ShowJoinGroupPrompt(result.SuggestedGroup);
            if (join && result.SuggestedGroup != null)
            {
                _controller.JoinGroup(_currentUserId, result.SuggestedGroup.GroupId, new List<Reminder>(_reminders));
                ShowSuccessMessage("Joined group meeting!");
                Close();
                return;
            }

            _controller.CreatePersonalAppointment(name, location, start, end, new List<Reminder>(_reminders));
            ShowSuccessMessage("Appointment created.");
            Close();
            return;
        }

        if (result.Status == SubmitStatus.Success)
        {
            ShowSuccessMessage(result.Message);
            Close();
        }
    }

    private void cancelButton_Click(object sender, EventArgs e)
    {
        ShowCancelMessage();
        Close();
    }
}
