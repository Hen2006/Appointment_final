using AppointmentApp.Model;

namespace AppointmentApp.Controller;

public class AppointmentController
{
    private readonly Calendar _calendar;
    private readonly GroupMeetingRepository _groupRepo;
    private readonly string _currentUserId;

    public AppointmentController(Calendar calendar, GroupMeetingRepository groupRepo, string currentUserId)
    {
        _calendar = calendar;
        _groupRepo = groupRepo;
        _currentUserId = currentUserId;
    }

    public SubmitResult SubmitAppointment(
        string name,
        string location,
        DateTime start,
        DateTime end,
        List<Reminder> reminders)
    {
        var validationResult = ValidateBusiness(name, location, start, end);
        if (validationResult != null)
        {
            return validationResult;
        }

        if (_calendar.IsTimeConflict(start, end))
        {
            var conflict = _calendar.FindFirstConflict(start, end);
            if (conflict != null && conflict.Name == name && conflict.Location == location)
            {
               // This is likely the exact exact same group meeting, let it fall through to EvaluateGroupMeetingOrCreate
            }
            else
            {
                if (conflict == null)
                {
                    conflict = new Appointment
                    {
                        Name = name,
                        Location = location,
                        StartTime = start,
                        EndTime = end
                    };
                }
                return SubmitResult.Conflict(conflict);
            }
        }

        // No conflict: continue to group meeting suggestion or create personal appointment.
        return EvaluateGroupMeetingOrCreate(name, location, start, end, reminders);
    }

    public SubmitResult ConfirmReplace(
        string oldAppId,
        string name,
        string location,
        DateTime start,
        DateTime end,
        List<Reminder> reminders)
    {
        _calendar.DeleteAppointment(oldAppId);
        return EvaluateGroupMeetingOrCreate(name, location, start, end, reminders);
    }

    public void JoinGroup(string userId, string groupId)
    {
        _groupRepo.AddParticipant(groupId, userId);
    }

    public void JoinGroup(string userId, string groupId, List<Reminder> reminders)
    {
        JoinGroup(userId, groupId);
        var appointment = _calendar.GetAppointmentById(groupId);
        if (appointment != null)
        {
            AddReminders(appointment, reminders);
        }
    }

    public Appointment CreatePersonalAppointment(
        string name,
        string location,
        DateTime start,
        DateTime end,
        List<Reminder> reminders)
    {
        var appointment = _calendar.AddAppointment(name, location, start, end);
        AddReminders(appointment, reminders);
        return appointment;
    }

    public List<Appointment> GetAppointmentsForUser()
    {
        return _calendar.GetAppointments();
    }

    public Appointment? GetAppointmentById(string appId)
    {
        return _calendar.GetAppointmentById(appId);
    }

    public void DeleteAppointment(string appId)
    {
        _calendar.DeleteAppointment(appId);
    }

    public void UpdateAppointment(string appId, string name, string location, DateTime start, DateTime end, List<Reminder> reminders)
    {
        _calendar.UpdateAppointment(appId, name, location, start, end, reminders);
    }

    public SubmitResult EvaluateGroupMeetingOrCreate(
        string name,
        string location,
        DateTime start,
        DateTime end,
        List<Reminder> reminders)
    {
        var matchingGroups = _groupRepo.FindGroupMeetingMatch(name, location, start, end);
        if (matchingGroups.Count > 0)
        {
            return SubmitResult.SuggestGroup(matchingGroups[0]);
        }

        var appointment = CreatePersonalAppointment(name, location, start, end, reminders);
        return SubmitResult.Success(appointment, "Appointment created.");
    }

    private SubmitResult? ValidateBusiness(string name, string location, DateTime start, DateTime end)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return SubmitResult.ValidationError("Name is required.");
        }

        if (string.IsNullOrWhiteSpace(location))
        {
            return SubmitResult.ValidationError("Location is required.");
        }

        if (end <= start)
        {
            return SubmitResult.ValidationError("End time must be after start time.");
        }

        return null;
    }

    private void AddReminders(Appointment appointment, List<Reminder> reminders)
    {
        foreach (var reminder in reminders)
        {
            _calendar.AddReminder(appointment, reminder.ReminderTime);
        }
    }
}
